[Unit]
Description=Lotus KPI Web Application
After=network.target docker.service
Requires=docker.service

[Service]
User=www-data
WorkingDirectory=/opt/kpi-web
# All secrets/config live in /opt/kpi-web/.env (see .env.example). Not committed.
EnvironmentFile=/opt/kpi-web/.env
ExecStart=/opt/kpi-web/venv/bin/gunicorn -w 1 -b 0.0.0.0:20000 app:app --timeout 120
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
