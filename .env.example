# Copy to .env and fill in real values. Used by docker-compose and the app.
# NEVER commit the real .env file.

# --- PostgreSQL (Dockerized on the VPS) ---
DB_NAME=kpi
DB_USER=kpi
DB_PASSWORD=change-this-to-a-strong-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Name of the Postgres Docker container (used by the backup job)
PG_CONTAINER=kpi-postgres

# --- App ---
SECRET_KEY=change-this-to-a-long-random-string
KPI_ADMIN_USER=admin
KPI_ADMIN_PASS=change-me

# --- Backups ---
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
# Set to 1 only if you want the app process to also run backups (normally systemd does).
ENABLE_INAPP_BACKUP=0
